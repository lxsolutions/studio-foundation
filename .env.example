# Copy to .env and adjust. NEVER commit .env. All defaults are localhost-only.
# Model: development (this file) / test (CI containers) / staging+production
# (never in this repo — see infra/environments/README.md).

# --- Local PostgreSQL (Docker Compose) ---
STUDIO_PG_PORT=5432
STUDIO_PG_DB=studio
STUDIO_PG_USER=studio
# Dev-only password for a localhost-bound container. Rotate freely; not a secret
# in the production sense, but still never committed outside *.example files.
STUDIO_PG_PASSWORD=studio_dev_password
DATABASE_URL=postgres://studio:studio_dev_password@127.0.0.1:5432/studio
# Host the app/tests connect to. Only needs to change alongside STUDIO_INFRA_REMOTE
# below (keep it matching DATABASE_URL's host).
STUDIO_PG_HOST=127.0.0.1

# --- Remote Docker host (optional) ---
# Leave STUDIO_INFRA_REMOTE unset to run infra/compose.yaml with the local Docker
# engine (default). Set it to an ssh host alias (see ~/.ssh/config) to instead sync
# infra/ there and run Docker over SSH — e.g. when the local machine can't run
# Docker itself (no virtualization support) but a Docker host is reachable over
# Tailscale. When set, also point STUDIO_PG_BIND_HOST/STUDIO_PG_HOST/DATABASE_URL's
# host at that machine's private (Tailscale) address, never 0.0.0.0.
#
# STUDIO_INFRA_REMOTE=<your-ssh-host-alias>
# STUDIO_INFRA_REMOTE_DIR=~/studio-foundation-infra
# STUDIO_PG_BIND_HOST=<remote-tailscale-ip>
# STUDIO_PG_HOST=<remote-tailscale-ip>
# DATABASE_URL=postgres://studio:<dev-password>@<remote-tailscale-ip>:5432/studio

# --- Services ---
STUDIO_CONTROL_API_ADDR=127.0.0.1:8080
STUDIO_DEDICATED_ADDR=127.0.0.1:8081
STUDIO_LOG=info

# --- Tool locations (auto-discovered if unset; set only if discovery fails) ---
# GODOT_BIN=C:/path/to/Godot_v4.7.1-stable_win64_console.exe
# BLENDER_BIN=C:/Program Files/Blender Foundation/Blender 5.2/blender.exe

# --- Browser smoke tests ---
# chrome | msedge | firefox (must be installed; Playwright uses the channel, no download)
STUDIO_BROWSER_CHANNEL=chrome
STUDIO_WEB_SERVE_PORT=8060
