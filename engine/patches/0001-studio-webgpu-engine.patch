+						// Firefox/wgpu enforces Metal's limit of 8 storage buffers per shader stage.
+						if (wgsl_buffer_stages.has(k)) {
+							entry.visibility = (WGPUShaderStage)wgsl_buffer_stages[k];
+						} else if (!wgsl_buffer_stages.is_empty()) {
