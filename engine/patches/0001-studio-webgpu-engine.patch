+				}
+				// Add the PC ring-buffer entry: PUSH_CONSTANT_RING_BINDING, uniform, hasDynamicOffset=true.
+				// Safety: skip if any existing entry is already at PUSH_CONSTANT_RING_BINDING.
+				bool has_pc_binding = false;
