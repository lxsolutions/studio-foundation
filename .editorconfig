root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.gd]
# Godot convention
indent_style = tab

[*.{yml,yaml,json,toml,tscn,tres,cfg}]
indent_size = 2

[*.rs]
indent_size = 4

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{ps1,bat,cmd}]
end_of_line = crlf
